# Application
APP_NAME=AI Virtual Teacher
DEBUG=true
ENVIRONMENT=development

# LLM Configuration
ZHIPU_API_KEY=your-api-key
LLM_PROVIDER=bailian
BAILIAN_API_KEY=your-api-key
BAILIAN_MODEL=qwen3-max
BAILIAN_ENABLE_THINKING=false


# OpenSandbox Configuration
OPENSANDBOX_SERVER_URL=http://localhost:8080
OPENSANDBOX_API_KEY=
SANDBOX_IMAGE=opensandbox/code-interpreter-manim:v1.0.2
SANDBOX_TIMEOUT=600
SANDBOX_MAX_MEMORY_MB=512
SANDBOX_MAX_CPUS=1.0

# CORS
CORS_ORIGINS=["*"]
